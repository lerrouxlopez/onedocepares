API_PORT=8000
DATABASE_URL=postgres://postgres:postgres@localhost:5432/onedocepares
RUST_LOG=info,tower_http=info
SESSION_COOKIE_NAME=odp_session
SECURE_COOKIES=false
SESSION_TTL_HOURS=24
UPLOADS_DIR=./uploads

# Default superadmin seeded on startup if no user with this email exists
SUPERADMIN_USER=
SUPERADMIN_PASSWORD=

# Email / SMTP (optional — leave SMTP_HOST unset to disable email)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=no-reply@onedocepares.com
